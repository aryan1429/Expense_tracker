# MongoDB Connection String
# Replace this with your actual MongoDB Atlas connection string
# Format: mongodb+srv://<username>:<password>@<cluster-url>/<database-name>?retryWrites=true&w=majority
# Example: mongodb+srv://myUser:myPassword@cluster0.abc123.mongodb.net/expenseTracker?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/expenseTracker

# To use MongoDB Atlas (recommended for production):
# 1. Create a MongoDB Atlas account at https://www.mongodb.com/cloud/atlas
# 2. Create a new cluster
# 3. In the Atlas dashboard, go to "Database Access" and add a database user
# 4. Go to "Network Access" and add your IP address to the whitelist (or add 0.0.0.0/0 for testing only)
# 5. Click "Connect" on your cluster and choose "Connect your application"
# 6. Copy the connection string and replace the placeholders with your credentials
# 7. Replace the MONGO_URI value above with your Atlas connection string
